{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "API REST para maindb: clientes con token (header `token`), alta y listados con estado de sync por cliente.",
        "title": "Aflujo API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8005",
    "basePath": "/",
    "paths": {
        "/api/clients": {
            "get": {
                "description": "Requiere headers admin (`user` y `token`).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "clients"
                ],
                "summary": "Listar clientes",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Usuario admin (MAIN_USER)",
                        "name": "user",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Token admin (MAIN_TOKEN)",
                        "name": "token",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.Client"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    }
                }
            },
            "post": {
                "description": "Requiere headers admin (`user` y `token`). El campo token de la respuesta solo se muestra en este alta.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "clients"
                ],
                "summary": "Registrar cliente",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Usuario admin (MAIN_USER)",
                        "name": "user",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Token admin (MAIN_TOKEN)",
                        "name": "token",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Nombre opcional",
                        "name": "body",
                        "in": "body",
                        "schema": {
                            "$ref": "#/definitions/transport.createClientBody"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/model.ClientCreatedResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    }
                }
            }
        },
        "/api/clients/{id}": {
            "put": {
                "description": "Requiere headers admin (`user` y `token`). No permite editar el usuario admin.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "clients"
                ],
                "summary": "Editar cliente",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Usuario admin (MAIN_USER)",
                        "name": "user",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Token admin (MAIN_TOKEN)",
                        "name": "token",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "ID del cliente",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "name opcional, rotate_token opcional",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/transport.updateClientBody"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.ClientUpdatedResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    }
                }
            },
            "delete": {
                "description": "Requiere headers admin (`user` y `token`). No permite eliminar el usuario admin.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "clients"
                ],
                "summary": "Eliminar cliente",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Usuario admin (MAIN_USER)",
                        "name": "user",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Token admin (MAIN_TOKEN)",
                        "name": "token",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "ID del cliente",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorJSON"
                        }
                    }
                }
            }
        },
        "/api/main": {
            "get": {
                "security": [
                    {
                        "TokenAuth": []
                    }
                ],
                "description": "Filtros opcionales combinables (query). Requiere header token.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "maindb"
                ],
                "summary": "Listar maindb",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Desde fecha (YYYY-MM-DD UTC)",
                        "name": "fromdate",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Categorías separadas por coma",
                        "name": "category",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filtrar por available: true, false, 1 o 0",
                        "name": "avariable",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Máximo de filas (1-1000)",
                        "name": "max",
                        "in": "query"
                    },
                    {
                        "enum": [
                            "asc",
                            "desc"
                        ],
                        "type": "string",
                        "description": "Orden por created_at",
                        "name": "ord",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.Response"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/model.Response"
                        }
                    },
                    "500": {
                        "description": "texto plano",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/main/{id}": {
            "get": {
                "security": [
                    {
                        "TokenAuth": []
